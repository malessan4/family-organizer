# ================================================================
#  VARIABLES DE ENTORNO - DESARROLLO LOCAL
#  ⚠️  NUNCA subir este archivo a Git (.gitignore ya lo protege)
#  ⚠️  Copiar este archivo y renombrarlo a ".env" para usarlo
# ================================================================

# --- Base de Datos (Neon PostgreSQL) ---
DB_URL=jdbc:postgresql://ep-wispy-waterfall-aco38h9j-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=PON_AQUI_TU_PASSWORD_DE_NEON

# --- JWT ---
# Debe ser una cadena aleatoria de al menos 32 caracteres
# Generá una en: https://www.uuidgenerator.net/ o con el comando:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PON_AQUI_UNA_CADENA_LARGA_Y_ALEATORIA_MINIMO_32_CHARS
JWT_EXPIRATION=86400000

# --- JPA ---
# En desarrollo: "update" (crea/modifica tablas automáticamente)
# En PRODUCCIÓN cambiar a: "validate" (solo valida, no modifica)
DDL_AUTO=update
SHOW_SQL=true

# --- CORS ---
# Solo el origen de tu frontend. En prod será tu dominio de Vercel.
ALLOWED_ORIGINS=http://localhost:3000

# --- Perfil de Spring ---
SPRING_PROFILES_ACTIVE=dev
